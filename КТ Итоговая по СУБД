-- 1 аномалия

SELECT 
    TABLE_NAME,
    COLUMN_NAME,
    CONSTRAINT_NAME,
    REFERENCED_TABLE_NAME
FROM
    INFORMATION_SCHEMA.KEY_COLUMN_USAGE
WHERE
    TABLE_SCHEMA = 'exam_bestfator'
    AND TABLE_NAME = 'loans'
    AND REFERENCED_TABLE_NAME IS NOT NULL;

